# Environment Variables — TechSolve Pro Mailer API
# Copy this to .env for local development
# On Render: set these in Dashboard → Your Service → Environment

# Get your free API key at https://resend.com → API Keys
RESEND_API_KEY=re_your_api_key_here

# Your email address to receive contact notifications
ADMIN_EMAIL=josephngangamunyui@gmail.com

# From address — use resend sandbox until your domain is verified:
#   Sandbox (works immediately):  TechSolve Pro <onboarding@resend.dev>
#   Custom domain (after verify): TechSolve Pro <noreply@techsolvepro.kesug.com>
FROM_EMAIL=TechSolve Pro <onboarding@resend.dev>

PORT=3000
