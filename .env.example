# Environment Variables — TechSolve Pro Mailer API (Brevo)
# Copy to .env for local dev | Set on Render Dashboard → Environment

# ── Brevo (Sendinblue) ──────────────────────────────────────────────────────
# Get free API key at https://app.brevo.com → Settings → API Keys
BREVO_API_KEY=xkeysib-your-api-key-here

# The verified sender email in your Brevo account
# After signup, verify josephngangamunyui@gmail.com in:
# Brevo → Senders & IP → Senders → Add a Sender
BREVO_SENDER_EMAIL=josephngangamunyui@gmail.com
FROM_NAME=TechSolve Pro

# Your admin email to receive contact notifications
ADMIN_EMAIL=josephngangamunyui@gmail.com

PORT=3000
